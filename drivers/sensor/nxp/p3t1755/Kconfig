# P3T1755 digital temperature sensor

# Copyright 2024 NXP
# SPDX-License-Identifier: Apache-2.0

menuconfig P3T1755
	bool "P3T1755 digital temperature sensor driver"
	default y
	depends on DT_HAS_NXP_P3T1755_ENABLED
	select I2C if $(dt_compat_on_bus,$(DT_COMPAT_NXP_P3T1755),i2c)
	select I3C if $(dt_compat_on_bus,$(DT_COMPAT_NXP_P3T1755),i3c)
	help
	  Enable driver for the P3T1755 digital temperature sensor.

if P3T1755

choice P3T1755_TRIGGER_MODE
	prompt "Trigger mode"
	default P3T1755_TRIGGER_GLOBAL_THREAD
	help
	  Specify the type of triggering to be used by the driver.

config P3T1755_TRIGGER_NONE
	bool "No trigger"

config P3T1755_TRIGGER_GLOBAL_THREAD
	bool "Use global thread"
	depends on GPIO
	select P3T1755_TRIGGER

config P3T1755_TRIGGER_OWN_THREAD
	bool "Use own thread"
	depends on GPIO
	select P3T1755_TRIGGER

endchoice # P3T1755_TRIGGER_MODE

config P3T1755_TRIGGER
	bool

endif # P3T1755
