config OTP_NXP_RT7XX_OCOTP
	bool "NXP RT7xx native OCOTP driver"
	default y
	depends on DT_HAS_NXP_RT7XX_OCOTP_ENABLED
	help
	  Enable the native OTP driver for the NXP RT7xx OCOTP controller.
	  This driver accesses the on-chip OTP shadow registers directly
	  without using the NXP HAL library.
